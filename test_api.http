POST {{baseUrl}}/auth/login
Content-Type: application/json

{
    "email": "member@greenstep.test",
    "password": "wrongpassword"
}

###

# ============================================================
# TEST 6 — GET /auth/me with valid token
# ============================================================
# EXPECTED 200:
# {
#   "id": <number>,
#   "name": "Demo Member",
#   "email": "member@greenstep.test",
#   "role": "member"
# }
# ============================================================
GET {{baseUrl}}/auth/me
Authorization: Bearer {{memberToken}}

###

# ============================================================
# TEST 7 — GET /auth/me with no token
# ============================================================
# EXPECTED 401:
# {
#   "error": "Missing or malformed token"
# }
# ============================================================
GET {{baseUrl}}/auth/me

###

# ============================================================
# TEST 8 — Log an activity with valid token
# ============================================================
# EXPECTED 201:
# {
#   "message": "Activity recorded successfully!",
#   "logged_item": {
#     "id": <number>,
#     "time": "<current time e.g. 02:30 PM>",
#     "activity": "Car (Petrol)",
#     "amount": 10,
#     "unit": "km",
#     "emissions_kg": 2.1
#   }
# }
# ============================================================
POST {{baseUrl}}/api/activities/log
Authorization: Bearer {{memberToken}}
Content-Type: application/json

{
    "activity_type_id": 1,
    "amount": 10,
    "date": "2026-06-17"
}

###

# ============================================================
# TEST 9 — Create a challenge with valid token
# ============================================================
# EXPECTED 201:
# {
#   "message": "Custom challenge posted successfully",
#   "challenge": {
#     "id": <number>,
#     "title": "My Test Challenge",
#     "description": "Reduce transport emissions this week",
#     "target_type": "transport",
#     "created_by": <your user id from JWT sub>,
#     "filters": ["all", "active"],
#     "has_joined": false,
#     "group_progress_percent": 0
#   }
# }
# ============================================================
# IMPORTANT: Note the challenge id and paste into @createdChallengeId below
# ============================================================
POST {{baseUrl}}/api/challenges
Authorization: Bearer {{memberToken}}
Content-Type: application/json

{
    "title": "My Test Challenge",
    "description": "Reduce transport emissions this week",
    "target_type": "transport"
}

###

# ============================================================
# SET THIS after running Test 9
# ============================================================
@createdChallengeId = 7

###

# ============================================================
# TEST 10 — Delete own challenge as creator
# ============================================================
# EXPECTED 200:
# {
#   "message": "Challenge deleted successfully"
# }
# ============================================================
DELETE {{baseUrl}}/api/challenges/{{createdChallengeId}}
Authorization: Bearer {{memberToken}}

###

# ============================================================
# BONUS TEST A — Delete a seeded challenge as member
# Seeded challenges have created_by = NULL so no one owns them
# ============================================================
# EXPECTED 403:
# {
#   "error": "Only the challenge creator can delete this challenge"
# }
# ============================================================
DELETE {{baseUrl}}/api/challenges/1
Authorization: Bearer {{memberToken}}

