============================================================
STEP 1 — Login as member to get fresh token
============================================================
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
    "email": "member@greenstep.test",
    "password": "password"
}


============================================================
STEP 2 — Check available activity types first
============================================================
GET {{baseUrl}}/api/activities/types

============================================================
STEP 3 — Log a Car (Petrol) activity (activity_type_id: 1)
10km x 0.21 kg/km = 2.1 kg CO2
============================================================
EXPECTED 201:
{
"message": "Activity recorded successfully!",
"logged_item": {
"activity": "Car (Petrol)",
"amount": 10,
"unit": "km",
"emissions_kg": 2.1
}
}
POST {{baseUrl}}/api/activities/log
Authorization: Bearer {{memberToken}}
Content-Type: application/json

{
    "activity_type_id": 1,
    "amount": 10,
    "date": "2026-06-20"
}

============================================================
STEP 4 — Check today's logs to confirm it was recorded
============================================================
EXPECTED 200:
[ { "activity": "Car (Petrol)", "emissions_kg": 2.1, ... } ]
GET {{baseUrl}}/api/activities/today
Authorization: Bearer {{memberToken}}

============================================================
STEP 5 — Check dashboard to see emissions updated
============================================================
EXPECTED 200:
{ "panels": { "today_emissions_kg": 2.1, "eco_points": { "current_total": 15, ... } } }
GET {{baseUrl}}/api/dashboard
Authorization: Bearer {{memberToken}}

