@baseUrl = http://localhost:8000
@memberEmail = you@greenstep.app
@adminEmail = admin@greenstep.app
@password = password








# ============================================================
# TEST 1 — Register a new user
# ============================================================
# EXPECTED 201:
# {
#   "message": "Registered",
#   "user": {
#     "id": <number>,
#     "name": "Test User",
#     "email": "testuser@greenstep.test",
#     "role": "member"
#   }
# }
# ============================================================

###
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
    "name": "Test User",
    "email": "testuser@greenstep.test",
    "password": "password123"
}

###

# ============================================================
# TEST 2 — Register with invalid data
# ============================================================
# EXPECTED 400:
# {
#   "errors": {
#     "name": "min 2 chars",
#     "email": "invalid email",
#     "password": "min 6 chars"
#   }
# }
# ============================================================
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
    "name": "A",
    "email": "not-an-email",
    "password": "123"
}

###
# ============================================================
# TEST 3 — Register duplicate email
# ============================================================
# EXPECTED 409:
# {
#   "error": "Email already registered"
# }
# ============================================================
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
    "name": "Test User",
    "email": "testuser@greenstep.test",
    "password": "password123"
}

###

# ============================================================
# TEST 4 — Login as member
# ============================================================
# EXPECTED 200:
# {
#   "token_type": "Bearer",
#   "expires_in": 3600,
#   "access_token": "<long JWT string eyJ...>"
# }
# ============================================================
# IMPORTANT: Copy access_token and paste into @memberToken below
# ============================================================
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
    "email": "{{memberEmail}}",
    "password": "{{password}}"
}

###

# ============================================================
# SET THIS after running Test 4
