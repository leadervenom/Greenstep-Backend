# .env.example — copy this to .env and fill in your own values

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=greenstep_api
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Application
APP_DEBUG=true

# JWT Authentication
# Generate your own secret with: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=your-generated-secret-here
JWT_TTL=3600
JWT_ISSUER=greenstep-api